<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/style.css">
    <title>Quora</title>
</head>
<body>
    <div class="body">
        <div class="body__header">
            <h1>Quora</h1>
        </div>
        <hr>
        <div class="posts__container">
            <h2 class="posts__heading">posts :-</h2>
            <% for( let i = 0; i < posts.length; i++ ) { %>
                <div class="post">
                    <p>id : <%= posts[i].id %></p>
                    <h3 class="post__username">@<%= posts[i].username %></h3>
                    <h4 class="post__content"><%= posts[i].content %></h4>
                    <a href="/posts/<%= posts[i].id %>">show</a>
                    <a href="/posts/<%= posts[i].id %>/edit">edit</a>
                    <form method="post" action="/posts/<%= posts[i].id %>?_method=DELETE" >
                        <button>Delete Post</button>
                    </form>
                </div>
            <% } %>
        </div>
        <a href="/posts/new" class="">Create Post</a>
    </div> 
</body>
</html>